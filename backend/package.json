{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "predev": "npm run prisma:generate && npm run db:push && npm run seed",
    "dev": "tsx watch src/app/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/app/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
